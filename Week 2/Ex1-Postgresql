#INNER JOIN

SELECT e.emp_id,
       e.emp_name,
       e.salary,
       d.dept_name
FROM Employee e
INNER JOIN Department d
ON e.dept_id = d.dept_id;

Output:
| emp_id | emp_name  | salary | dept_name |
