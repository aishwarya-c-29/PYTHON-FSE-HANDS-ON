#SELF JOIN

#Create a another table
CREATE TABLE Staff (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    manager_id INT
);

INSERT INTO Staff
VALUES
(1,'John',NULL),
(2,'Alice',1),
(3,'Bob',1),
(4,'David',2);

#Employees with their managers
SELECT e.emp_name AS Employee,
       m.emp_name AS Manager
FROM Staff e
LEFT JOIN Staff m
ON e.manager_id = m.emp_id;

Output:
| Employee | Manager |
| -------- | ------- |
| John     | NULL    |
| Alice    | John    |
| Bob      | John    |
| David    | Alice   |


